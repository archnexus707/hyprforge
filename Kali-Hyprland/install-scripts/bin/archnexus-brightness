#!/usr/bin/env bash
# archnexus-brightness — wrap brightnessctl / light with an OSD via notify-send.
#
# Usage:  archnexus-brightness up [pct]
#         archnexus-brightness down [pct]
#         archnexus-brightness set <pct>
#         archnexus-brightness get
#
# Step defaults to 5%.

set -uo pipefail

step="${2:-5}"

if command -v brightnessctl >/dev/null 2>&1; then
    case "${1:-get}" in
        up)   brightnessctl set "${step}%+" >/dev/null ;;
        down) brightnessctl set "${step}%-" >/dev/null ;;
        set)  brightnessctl set "${2:-50}%" >/dev/null ;;
        get|*) ;;
    esac
    cur=$(brightnessctl --machine | awk -F, '{print $4}' | tr -d '%')
elif command -v light >/dev/null 2>&1; then
    case "${1:-get}" in
        up)   light -A "$step" ;;
        down) light -U "$step" ;;
        set)  light -S "${2:-50}" ;;
        get|*) ;;
    esac
    cur=$(printf '%.0f' "$(light -G)")
else
    echo "install brightnessctl or light" >&2; exit 1
fi

# Build a 20-cell progress bar
bar=""
for i in $(seq 0 19); do
    if [ "$((i*5))" -lt "$cur" ]; then bar="${bar}█"; else bar="${bar}░"; fi
done

notify-send -h string:x-canonical-private-synchronous:archnexus-brightness \
    -i display-brightness "Brightness: ${cur}%" "$bar" 2>/dev/null || \
    echo "Brightness: ${cur}%  $bar"
