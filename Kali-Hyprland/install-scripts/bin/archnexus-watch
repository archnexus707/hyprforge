#!/usr/bin/env bash
# archnexus-watch — watch ~/.config/{hypr,kitty,dunst,rofi,picom,i3} and
# auto-reload the right daemon on save. Pure-bash polling fallback if
# `entr` and `inotifywait` are both missing.
#
# Run once:           archnexus-watch
# Run as a daemon:    systemctl --user start archnexus-watch.service
# (The .service unit is dropped by cli-tools.sh during install.)

set -uo pipefail

DIRS=(
    "$HOME/.config/hypr"
    "$HOME/.config/i3"
    "$HOME/.config/kitty"
    "$HOME/.config/dunst"
    "$HOME/.config/rofi"
    "$HOME/.config/picom"
)
DIRS=( $(printf '%s\n' "${DIRS[@]}" | while read -r d; do [ -d "$d" ] && echo "$d"; done) )

_reload() {
    local path="$1"
    case "$path" in
        *hypr/*)
            if command -v hyprctl >/dev/null && [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; then
                hyprctl reload >/dev/null 2>&1 && notify-send "archnexus-watch" "hyprctl reload" 2>/dev/null
            fi ;;
        *i3/*)
            if command -v i3-msg >/dev/null && pgrep -x i3 >/dev/null; then
                i3-msg reload >/dev/null 2>&1 && notify-send "archnexus-watch" "i3 reload" 2>/dev/null
            fi ;;
        *kitty/*)
            # kitty reloads its config on SIGUSR1 if `allow_remote_control` is on
            pkill -SIGUSR1 -x kitty 2>/dev/null && notify-send "archnexus-watch" "kitty reload" 2>/dev/null
            ;;
        *dunst/*)
            pkill -x dunst 2>/dev/null
            (setsid -f dunst >/dev/null 2>&1 &) && notify-send "archnexus-watch" "dunst restart" 2>/dev/null
            ;;
        *rofi/*)
            : # rofi reads config on each invocation; nothing to reload
            ;;
        *picom/*)
            pkill -SIGUSR1 picom 2>/dev/null && notify-send "archnexus-watch" "picom reload" 2>/dev/null
            ;;
    esac
}

_watch_inotify() {
    while inotifywait -qq -e close_write,modify,create,move,delete -r "${DIRS[@]}" --format '%w%f' 2>/dev/null; do
        # inotifywait prints the changed path on stdout — capture via subst:
        # but with -qq we lose the path. Use -m for monitor mode instead.
        :
    done
}

_watch_inotify_mon() {
    inotifywait -m -r -e close_write,modify,create,move,delete --format '%w%f' "${DIRS[@]}" 2>/dev/null \
    | while read -r path; do
        _reload "$path"
        # debounce a touch — many editors emit multiple events
        sleep 0.5
    done
}

_watch_entr() {
    local stamp="/tmp/.archnexus-watch-stamp"
    touch "$stamp"
    find "${DIRS[@]}" -type f 2>/dev/null | entr -d -p sh -c '
        for d in '"${DIRS[*]}"'; do
            [ -d "$d" ] && find "$d" -newer '"$stamp"' -type f 2>/dev/null
        done | while read -r f; do
            case "$f" in
                *picom*) pkill -SIGUSR1 picom 2>/dev/null && notify-send "archnexus-watch" "picom reload" 2>/dev/null ;;
            esac
        done
        touch '"$stamp"'
    '
}

_watch_poll() {
    # 5-second poll fallback. Slow but works without extra tools.
    local stamp="/tmp/.archnexus-watch-stamp"
    touch "$stamp"
    while sleep 5; do
        for d in "${DIRS[@]}"; do
            changed=$(find "$d" -type f -newer "$stamp" 2>/dev/null | head -1)
            if [ -n "$changed" ]; then
                _reload "$changed"
            fi
        done
        touch "$stamp"
    done
}

main() {
    if [ "${#DIRS[@]}" -eq 0 ]; then
        echo "no config directories to watch" >&2
        exit 1
    fi
    echo "watching: ${DIRS[*]}"
    if command -v inotifywait >/dev/null 2>&1; then
        _watch_inotify_mon
    elif command -v entr >/dev/null 2>&1; then
        _watch_entr
    else
        echo "(neither inotifywait nor entr found — using 5s poll fallback)" >&2
        _watch_poll
    fi
}

main "$@"
