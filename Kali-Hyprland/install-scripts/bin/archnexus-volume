#!/usr/bin/env bash
# archnexus-volume — wrap wpctl with an OSD overlay via notify-send.
#
# Usage:  archnexus-volume up [pct]
#         archnexus-volume down [pct]
#         archnexus-volume mute
#         archnexus-volume set <pct>
#         archnexus-volume get

set -uo pipefail

if ! command -v wpctl >/dev/null 2>&1; then
    echo "install wireplumber (apt install wireplumber)" >&2; exit 1
fi

SINK="@DEFAULT_AUDIO_SINK@"
step="${2:-5}"

case "${1:-get}" in
    up)    wpctl set-volume -l 1.5 "$SINK" "${step}%+" ;;
    down)  wpctl set-volume    "$SINK" "${step}%-" ;;
    mute)  wpctl set-mute      "$SINK" toggle ;;
    set)   wpctl set-volume -l 1.5 "$SINK" "${2:-50}%" ;;
    get|*) ;;
esac

read -r _ raw < <(wpctl get-volume "$SINK")
vol_pct=$(awk -v v="$raw" 'BEGIN{ printf "%d", v*100 }')
muted_flag=""
wpctl get-volume "$SINK" | grep -q "MUTED" && muted_flag=" 🔇"

bar=""
for i in $(seq 0 19); do
    if [ "$((i*5))" -lt "$vol_pct" ]; then bar="${bar}█"; else bar="${bar}░"; fi
done

notify-send -h string:x-canonical-private-synchronous:archnexus-volume \
    -i audio-volume-medium "Volume: ${vol_pct}%${muted_flag}" "$bar" 2>/dev/null || \
    echo "Volume: ${vol_pct}%${muted_flag}  $bar"
