#!/usr/bin/env bash
# archnexus-sync — push/pull your dotfiles to a private git remote.
#
# Tracks (configurable via ~/.config/archnexus/sync.conf):
#   ~/.config/hypr        ~/.config/kitty        ~/.config/dunst
#   ~/.config/rofi        ~/.config/i3           ~/.config/picom
#   ~/.zshrc              ~/.p10k.zsh            ~/.config/archnexus/local.preset
#
# Secrets path (regex-matched filenames) are encrypted with `age` before
# commit when an age key is configured (~/.config/archnexus/age.key).
#
# Usage:
#   archnexus-sync init <git-remote-url>     clone or init repo at ~/.archnexus-dots
#   archnexus-sync push [message]            copy → commit → push
#   archnexus-sync pull                      pull → copy back to $HOME
#   archnexus-sync status                    diff against tracked files
#   archnexus-sync where                     print repo path
#   archnexus-sync edit                      open sync.conf in $EDITOR

set -uo pipefail

REPO="${ARCHNEXUS_SYNC_REPO:-$HOME/.archnexus-dots}"
CONF="$HOME/.config/archnexus/sync.conf"
AGE_KEY="$HOME/.config/archnexus/age.key"

# Default track list — override by writing sync.conf
DEFAULT_TRACK=(
    ".config/hypr"
    ".config/kitty"
    ".config/dunst"
    ".config/rofi"
    ".config/i3"
    ".config/picom"
    ".zshrc"
    ".p10k.zsh"
    ".config/archnexus/local.preset"
)
SECRET_PATTERN='(secret|token|password|api[-_]?key|\.env$|\.pem$)'

_load_conf() {
    TRACK=("${DEFAULT_TRACK[@]}")
    if [ -f "$CONF" ]; then
        # shellcheck disable=SC1090
        . "$CONF"
    fi
}

_ensure_repo() {
    if [ ! -d "$REPO/.git" ]; then
        echo "archnexus-sync: repo not initialised. Run: archnexus-sync init <git-url>" >&2
        return 1
    fi
}

_cmd_init() {
    local url="${1:-}"
    mkdir -p "$REPO"
    if [ -z "$url" ]; then
        ( cd "$REPO" && git init -q && git checkout -b main 2>/dev/null || git checkout main )
    else
        if [ -d "$REPO/.git" ]; then
            ( cd "$REPO" && git remote set-url origin "$url" )
        else
            git clone "$url" "$REPO" 2>/dev/null || ( mkdir -p "$REPO" && cd "$REPO" && git init -q && git remote add origin "$url" )
        fi
    fi
    mkdir -p "$(dirname "$CONF")"
    if [ ! -f "$CONF" ]; then
        cat > "$CONF" <<EOF
# archnexus-sync override file. Bash-sourced.
# Override TRACK=(...) below to change what gets pushed.
# Override SECRET_PATTERN to control which files get age-encrypted.

# TRACK=("\${DEFAULT_TRACK[@]}" ".config/my-extra-thing")
# SECRET_PATTERN='(secret|token|password|\.env\$)'
EOF
    fi
    echo "archnexus-sync: ready at $REPO"
}

_should_encrypt() {
    [ -f "$AGE_KEY" ] || return 1
    case "$1" in
        *[Ss]ecret*|*[Tt]oken*|*[Pp]assword*|*api*key*|*.env|*.pem) return 0 ;;
    esac
    [ -n "${SECRET_PATTERN:-}" ] && grep -qE "$SECRET_PATTERN" <<<"$1" && return 0
    return 1
}

_copy_in() {
    # $HOME/<path> → $REPO/<path>
    local p="$1"
    local src="$HOME/$p"
    local dst="$REPO/$p"
    [ -e "$src" ] || return 0
    mkdir -p "$(dirname "$dst")"
    if _should_encrypt "$src"; then
        if command -v age >/dev/null 2>&1; then
            age -R "$AGE_KEY" -o "${dst}.age" "$src"
            rm -f "$dst" 2>/dev/null
        else
            echo "archnexus-sync: $src looks sensitive but 'age' is not installed; SKIPPING" >&2
            return 0
        fi
    else
        rsync -a --delete "$src" "$(dirname "$dst")/" 2>/dev/null || cp -a "$src" "$dst"
    fi
}

_copy_out() {
    # $REPO/<path> → $HOME/<path>
    local p="$1"
    local src="$REPO/$p"
    local dst="$HOME/$p"
    if [ -e "${src}.age" ]; then
        if command -v age >/dev/null 2>&1 && [ -f "$AGE_KEY" ]; then
            mkdir -p "$(dirname "$dst")"
            age -d -i "$AGE_KEY" -o "$dst" "${src}.age"
        else
            echo "archnexus-sync: ${src}.age present but age key missing; SKIPPING" >&2
        fi
    elif [ -e "$src" ]; then
        mkdir -p "$(dirname "$dst")"
        rsync -a --delete "$src" "$(dirname "$dst")/" 2>/dev/null || cp -a "$src" "$dst"
    fi
}

_cmd_push() {
    _ensure_repo || return 1
    _load_conf
    local msg="${1:-sync from $(hostname) at $(date -Iseconds)}"
    cd "$REPO"
    for p in "${TRACK[@]}"; do _copy_in "$p"; done
    git add -A
    if git diff --cached --quiet; then
        echo "archnexus-sync: nothing to commit"
        return 0
    fi
    git commit -m "$msg"
    if git remote get-url origin >/dev/null 2>&1; then
        git push -u origin "$(git symbolic-ref --short HEAD)"
    else
        echo "archnexus-sync: no remote configured; committed locally."
    fi
}

_cmd_pull() {
    _ensure_repo || return 1
    _load_conf
    cd "$REPO"
    if git remote get-url origin >/dev/null 2>&1; then
        git pull --ff-only
    fi
    for p in "${TRACK[@]}"; do _copy_out "$p"; done
    echo "archnexus-sync: pulled into \$HOME"
}

_cmd_status() {
    _ensure_repo || return 1
    _load_conf
    cd "$REPO"
    echo "= tracked entries ="
    printf '  %s\n' "${TRACK[@]}"
    echo
    echo "= git status ="
    git status -s
    echo
    echo "= unsynced changes in \$HOME ="
    for p in "${TRACK[@]}"; do
        if [ -e "$HOME/$p" ] && [ -e "$REPO/$p" ]; then
            diff -rq "$HOME/$p" "$REPO/$p" 2>/dev/null | head -5
        elif [ -e "$HOME/$p" ]; then
            echo "  $p — NEW (not yet pushed)"
        fi
    done
}

case "${1:-}" in
    init)   shift; _cmd_init "$@" ;;
    push)   shift; _cmd_push "$@" ;;
    pull)   _cmd_pull ;;
    status) _cmd_status ;;
    where)  echo "$REPO" ;;
    edit)   "${EDITOR:-nano}" "$CONF" ;;
    "")     echo "usage: archnexus-sync init <url> | push [msg] | pull | status | where | edit" ;;
    *)      echo "unknown subcommand: $1" >&2; exit 1 ;;
esac
