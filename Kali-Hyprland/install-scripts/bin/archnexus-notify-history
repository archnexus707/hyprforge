#!/usr/bin/env bash
# archnexus-notify-history — pop the last dunst notifications via rofi/wofi.
# On Hyprland with swaync, defers to `swaync-client -t`.
#
# Bind it: Super+N

set -uo pipefail

# swaync (Hyprland notification center) — preferred when available
if command -v swaync-client >/dev/null 2>&1 && pgrep -x swaync >/dev/null 2>&1; then
    swaync-client -t -sw
    exit 0
fi

# dunst path
if ! command -v dunstctl >/dev/null 2>&1; then
    echo "dunstctl not installed (apt install dunst)" >&2
    exit 1
fi

mode="${1:-pop}"
case "$mode" in
    pop|--pop)   dunstctl history-pop ;;
    clear|--clear) dunstctl close-all; dunstctl history-clear ;;
    list|--list)
        # Pretty-print history JSON via jq if present; else raw
        if command -v jq >/dev/null 2>&1; then
            dunstctl history | jq -r '.data[0][] | "[\(.timestamp.data | tostring | .[0:10]))] \(.appname.data) — \(.summary.data) — \(.body.data)"'
        else
            dunstctl history
        fi ;;
    *) echo "usage: $0 [pop|clear|list]" >&2; exit 1 ;;
esac
