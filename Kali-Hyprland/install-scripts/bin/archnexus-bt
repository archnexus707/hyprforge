#!/usr/bin/env bash
# archnexus-bt — rofi/wofi bluetooth picker. Scans, lists known + nearby
# devices, connects/disconnects/forgets on selection.
#
# Bind it: Super+B (or whatever)

set -uo pipefail

if ! command -v bluetoothctl >/dev/null 2>&1; then
    notify-send "archnexus-bt" "bluetoothctl not installed (apt install bluez)" 2>/dev/null || \
        echo "bluetoothctl not installed (apt install bluez)" >&2
    exit 1
fi

_pick() {
    if   command -v rofi >/dev/null 2>&1; then rofi -dmenu -p "  Bluetooth" -i -theme-str 'window {width: 50%; border: 2px solid; border-color: #00ff9c;} element selected {background-color: #00ff9c; text-color: #0a0a0a;} prompt {text-color: #00ff9c;}'
    elif command -v wofi >/dev/null 2>&1; then wofi --dmenu --prompt "Bluetooth"
    else fzf
    fi
}

# Ensure controller is powered + scanning briefly so nearby devices show up.
bluetoothctl power on >/dev/null 2>&1 || true
bluetoothctl scan on >/dev/null 2>&1 &
SCAN_PID=$!
sleep 3
kill "$SCAN_PID" 2>/dev/null || true
bluetoothctl scan off >/dev/null 2>&1 || true

# Build the device list:  MAC  NAME  [connected]
mapfile -t devs < <(bluetoothctl devices | awk '{ $1=""; mac=""; name=substr($0,2); print $0 }')
mapfile -t paired_list < <(bluetoothctl paired-devices 2>/dev/null || true)

choice=$(printf '%s\n' "${devs[@]}" | _pick)
[ -z "$choice" ] && exit 0

mac=$(awk '{print $2}' <<<"$choice")
[ -z "$mac" ] && exit 0

action=$(printf 'connect\ndisconnect\npair\ntrust\nforget\n' | _pick)
case "$action" in
    connect)    bluetoothctl connect "$mac" ;;
    disconnect) bluetoothctl disconnect "$mac" ;;
    pair)       bluetoothctl pair "$mac" ;;
    trust)      bluetoothctl trust "$mac" ;;
    forget)     bluetoothctl remove "$mac" ;;
esac
