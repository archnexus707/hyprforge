#!/usr/bin/env bash
# archnexus-theme — unified theme hot-swap.
#
# Usage:
#   archnexus-theme list                       list known themes
#   archnexus-theme <name>                     switch to <name>
#   archnexus-theme rofi                       pick interactively
#   archnexus-theme current                    print active theme
#
# Themes live in install-scripts/themes/<name>.theme — bash files with
# THEME_*, GTK_*, KITTY_*, DUNST_*, ROFI_*, HYPR_*, I3_* vars.
#
# Updates atomically: GTK + icon + cursor (via gsettings/xfconf), Qt
# (kvantum via env), kitty (regen colors), rofi colors block, dunst frame
# color, Hyprland border colors, i3 client.focused colors.

set -uo pipefail

# Resolve the project root from this script's path.
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
PROJ_ROOT="$(cd "$(dirname "$SELF")/../.." && pwd)"
THEME_DIR="$PROJ_ROOT/install-scripts/themes"
STATE="$HOME/.cache/archnexus/active-theme"
mkdir -p "$(dirname "$STATE")"

_list() {
    [ -d "$THEME_DIR" ] || { echo "no theme dir at $THEME_DIR"; return 1; }
    for f in "$THEME_DIR"/*.theme; do
        [ -f "$f" ] || continue
        basename "$f" .theme
    done | sort
}

_current() {
    [ -f "$STATE" ] && cat "$STATE" || echo "(unset)"
}

_apply_gtk() {
    if command -v gsettings >/dev/null 2>&1; then
        gsettings set org.gnome.desktop.interface gtk-theme    "$GTK_THEME"   2>/dev/null || true
        gsettings set org.gnome.desktop.interface icon-theme   "$ICON_THEME"  2>/dev/null || true
        gsettings set org.gnome.desktop.interface cursor-theme "$CURSOR_THEME" 2>/dev/null || true
        gsettings set org.gnome.desktop.interface color-scheme "prefer-dark"   2>/dev/null || true
    fi
    if command -v xfconf-query >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
        xfconf-query -c xsettings -p /Net/ThemeName  -s "$GTK_THEME"  2>/dev/null || \
            xfconf-query -c xsettings -p /Net/ThemeName --create --type string -s "$GTK_THEME" 2>/dev/null
        xfconf-query -c xsettings -p /Net/IconThemeName -s "$ICON_THEME" 2>/dev/null || \
            xfconf-query -c xsettings -p /Net/IconThemeName --create --type string -s "$ICON_THEME" 2>/dev/null
        xfconf-query -c xsettings -p /Gtk/CursorThemeName -s "$CURSOR_THEME" 2>/dev/null || true
    fi
    # GTK 3/4 settings.ini for apps that read it directly
    for ini in "$HOME/.config/gtk-3.0/settings.ini" "$HOME/.config/gtk-4.0/settings.ini"; do
        mkdir -p "$(dirname "$ini")"
        cat > "$ini" <<EOF
[Settings]
gtk-theme-name=$GTK_THEME
gtk-icon-theme-name=$ICON_THEME
gtk-cursor-theme-name=$CURSOR_THEME
gtk-application-prefer-dark-theme=1
EOF
    done
}

_apply_qt() {
    # Drop a small env file so Qt apps started after this point pick up the
    # right platform theme + Kvantum config.
    local env_dir="$HOME/.config/environment.d"
    mkdir -p "$env_dir"
    cat > "$env_dir/95-archnexus-qt.conf" <<EOF
QT_QPA_PLATFORMTHEME=qt6ct
QT_STYLE_OVERRIDE=kvantum
EOF
    # Tell Kvantum which theme to use (if installed)
    if command -v kvantummanager >/dev/null 2>&1 && [ -n "${QT_KVANTUM:-}" ]; then
        local kdir="$HOME/.config/Kvantum"
        mkdir -p "$kdir"
        cat > "$kdir/kvantum.kvconfig" <<EOF
[General]
theme=$QT_KVANTUM
EOF
    fi
}

_apply_kitty() {
    local conf="$HOME/.config/kitty/colors-archnexus.conf"
    mkdir -p "$(dirname "$conf")"
    cat > "$conf" <<EOF
# Auto-generated by archnexus-theme — do not edit; will be overwritten.
background  $KITTY_BG
foreground  $KITTY_FG
cursor      $KITTY_CURSOR
selection_background $KITTY_ACCENT
url_color   $KITTY_ACCENT
active_border_color $KITTY_ACCENT
EOF
    # Idempotent include in main kitty.conf
    local main="$HOME/.config/kitty/kitty.conf"
    if [ -f "$main" ] && ! grep -q "colors-archnexus.conf" "$main"; then
        printf '\ninclude colors-archnexus.conf\n' >> "$main"
    fi
    # Live reload if kitty is running and allow_remote_control is on
    pkill -SIGUSR1 -x kitty 2>/dev/null || true
}

_apply_dunst() {
    local rc="$HOME/.config/dunst/dunstrc"
    [ -f "$rc" ] || return 0
    # Replace background/foreground/frame_color in the [urgency_normal] block (best-effort)
    sed -i -E \
        -e "s|^(\s*background\s*=).*|\1 \"$DUNST_BG\"|" \
        -e "s|^(\s*foreground\s*=).*|\1 \"$DUNST_FG\"|" \
        -e "s|^(\s*frame_color\s*=).*|\1 \"$DUNST_FRAME\"|" \
        "$rc"
    pkill -x dunst 2>/dev/null
    setsid -f dunst >/dev/null 2>&1 &
}

_apply_rofi() {
    local rasi="$HOME/.config/rofi/colors-archnexus.rasi"
    mkdir -p "$(dirname "$rasi")"
    cat > "$rasi" <<EOF
/* Auto-generated by archnexus-theme. */
* {
    bg: $ROFI_BG;
    fg: $ROFI_FG;
    accent: $ROFI_ACCENT;
    background-color: @bg;
    text-color: @fg;
}
window { background-color: @bg; border: 2; border-color: @accent; }
element selected.normal { background-color: @accent; text-color: @bg; }
EOF
    local main="$HOME/.config/rofi/config.rasi"
    if [ -f "$main" ] && ! grep -q "colors-archnexus.rasi" "$main"; then
        printf '\n@import "colors-archnexus.rasi"\n' >> "$main"
    fi
}

_apply_hyprland() {
    local conf="$HOME/.config/hypr/hyprland.conf"
    [ -f "$conf" ] || return 0
    # Block: # archnexus-theme-START … # archnexus-theme-END
    local block_start="# archnexus-theme-START"
    local block_end="# archnexus-theme-END"
    local payload
    payload=$(cat <<EOF
$block_start
general {
    col.active_border = $HYPR_BORDER_ACTIVE
    col.inactive_border = $HYPR_BORDER_INACTIVE
}
$block_end
EOF
)
    if grep -q "$block_start" "$conf"; then
        # replace existing block
        awk -v start="$block_start" -v end="$block_end" -v payload="$payload" '
            BEGIN{skip=0}
            $0 ~ start {print payload; skip=1; next}
            $0 ~ end   {skip=0; next}
            skip==0    {print}
        ' "$conf" > "$conf.tmp" && mv "$conf.tmp" "$conf"
    else
        printf '\n%s\n' "$payload" >> "$conf"
    fi
    # Live reload
    if [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] && command -v hyprctl >/dev/null; then
        hyprctl reload >/dev/null 2>&1 || true
    fi
}

_apply_i3() {
    local conf="$HOME/.config/i3/config"
    [ -f "$conf" ] || return 0
    # Replace the THEME-START / THEME-END block our dotfiles ship with.
    awk -v fc="$I3_BORDER_FOCUSED" -v uc="$I3_BORDER_UNFOCUSED" '
        /THEME-START/ {
            print
            printf "client.focused          %s #313244 #cdd6f4 %s   %s\n", fc, fc, fc
            printf "client.focused_inactive %s #1e1e2e #cdd6f4 %s   %s\n", uc, uc, uc
            printf "client.unfocused        %s #1e1e2e #6c7086 %s   %s\n", uc, uc, uc
            printf "client.urgent           #f38ba8 #1e1e2e #1e1e2e #f38ba8   #f38ba8\n"
            skip=1; next
        }
        /THEME-END/   { skip=0 }
        skip!=1       { print }
    ' "$conf" > "$conf.tmp" && mv "$conf.tmp" "$conf"
    pgrep -x i3 >/dev/null && i3-msg reload >/dev/null 2>&1 || true
}

_apply() {
    local name="$1"
    local f="$THEME_DIR/$name.theme"
    if [ ! -f "$f" ]; then
        echo "unknown theme: $name. Try: archnexus-theme list" >&2
        return 1
    fi
    # shellcheck disable=SC1090
    . "$f"
    echo "[archnexus-theme] applying: $THEME_NAME"
    _apply_gtk
    _apply_qt
    _apply_kitty
    _apply_dunst
    _apply_rofi
    _apply_hyprland
    _apply_i3
    echo "$THEME_NAME" > "$STATE"
    notify-send "Theme" "switched to $THEME_NAME" 2>/dev/null || true
    echo "[archnexus-theme] active theme is now: $THEME_NAME"
}

_pick_rofi() {
    local choice
    choice=$(_list | (command -v rofi >/dev/null && rofi -dmenu -p "🎨 Theme" || wofi --dmenu --prompt "Theme"))
    [ -z "$choice" ] && exit 0
    _apply "$choice"
}

case "${1:-}" in
    list)    _list ;;
    current) _current ;;
    rofi)    _pick_rofi ;;
    "")      _list; echo; echo "current: $(_current)"; echo; echo "usage: archnexus-theme <name|list|rofi|current>" ;;
    *)       _apply "$1" ;;
esac
