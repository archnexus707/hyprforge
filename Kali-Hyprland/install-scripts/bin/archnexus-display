#!/usr/bin/env bash
# archnexus-display — multi-monitor + hotplug helper.
#
# Auto-detects compositor:
#   Hyprland (Wayland)  → write ~/.config/hypr/monitors.conf with a sane
#                         wildcard so HDMI/VGA/DP plug-and-play just works;
#                         hyprctl reload at end. Hot-plug works natively in
#                         Hyprland once the wildcard is in place.
#   i3 / X11            → use autorandr. `detect` saves a profile, `auto`
#                         re-applies. udev hook (installed by the install
#                         script) calls `autorandr --change` on hotplug.
#
# Usage:
#   archnexus-display detect           save / refresh layout for current monitor set
#   archnexus-display auto             re-apply best-matching saved profile
#   archnexus-display list             list current outputs + status
#   archnexus-display mirror           mirror all displays
#   archnexus-display extend           extend (Hyprland: wildcard; X11: --auto)
#   archnexus-display lid-close-external  set up lid-close → external-only handler

set -uo pipefail

_is_wayland() { [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; }

_hyprland_monitors_conf() {
    local conf="$HOME/.config/hypr/monitors.conf"
    mkdir -p "$(dirname "$conf")"
    cat > "$conf" <<'EOF'
# Auto-generated by archnexus-display.
# Wildcard line: any newly-connected monitor gets preferred resolution at its
# native refresh + auto position. Hot-plug works without further action.
monitor=,preferred,auto,1

# Override per-output here if you want a specific layout, e.g.:
#   monitor=eDP-1,1920x1080@60,0x0,1
#   monitor=HDMI-A-1,1920x1080@60,1920x0,1
#   monitor=DP-1,disable
EOF
    # ensure main hyprland.conf sources us
    local main="$HOME/.config/hypr/hyprland.conf"
    if [ -f "$main" ] && ! grep -q "^source[[:space:]]*=.*monitors.conf" "$main"; then
        printf '\nsource = ~/.config/hypr/monitors.conf\n' >> "$main"
    fi
    echo "wrote $conf (wildcard plug-and-play)"
    if [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] && command -v hyprctl >/dev/null; then
        hyprctl reload >/dev/null 2>&1 || true
    fi
}

_hyprland_lid_handler() {
    # Closes lid → disable eDP-1, restore on open. Best-effort; depends on
    # eDP-1 being the internal output name.
    local conf="$HOME/.config/hypr/lid.conf"
    cat > "$conf" <<'EOF'
# Auto-generated by archnexus-display.
bindl=,switch:on:Lid Switch,exec,hyprctl keyword monitor "eDP-1,disable"
bindl=,switch:off:Lid Switch,exec,hyprctl keyword monitor "eDP-1,preferred,auto,1"
EOF
    local main="$HOME/.config/hypr/hyprland.conf"
    if [ -f "$main" ] && ! grep -q "^source[[:space:]]*=.*lid.conf" "$main"; then
        printf '\nsource = ~/.config/hypr/lid.conf\n' >> "$main"
    fi
    echo "wrote $conf (lid-close handler)"
    [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] && hyprctl reload >/dev/null 2>&1 || true
}

_hyprland_list() {
    if command -v hyprctl >/dev/null && [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; then
        hyprctl monitors
    elif command -v wlr-randr >/dev/null; then
        wlr-randr
    else
        echo "no Hyprland/wlr-randr running" >&2; return 1
    fi
}

_x11_detect_or_save() {
    if ! command -v autorandr >/dev/null 2>&1; then
        echo "install autorandr first (apt install autorandr)" >&2; return 1
    fi
    local n; n=$(xrandr --query | grep -c " connected")
    local profile
    if [ "$n" -le 1 ]; then profile="single"; else profile="multi-$n"; fi
    autorandr --save "$profile" --force
    echo "saved autorandr profile: $profile"
}

_x11_auto() {
    if ! command -v autorandr >/dev/null 2>&1; then
        echo "install autorandr first (apt install autorandr)" >&2; return 1
    fi
    autorandr --change
}

_x11_list() {
    xrandr --query | awk '/connected|disconnected/ {print "  " $1 " — " $2}'
}

_x11_mirror() {
    # Mirror all currently-connected outputs onto the primary
    local primary
    primary=$(xrandr --query | awk '/ connected primary/ {print $1; exit}')
    [ -z "$primary" ] && primary=$(xrandr --query | awk '/ connected/ {print $1; exit}')
    [ -z "$primary" ] && { echo "no primary output found" >&2; return 1; }
    while read -r out; do
        [ "$out" = "$primary" ] && continue
        xrandr --output "$out" --auto --same-as "$primary"
    done < <(xrandr --query | awk '/ connected/ {print $1}')
}

_x11_extend() {
    # Extend all connected outputs in left-to-right order
    local prev=""
    while read -r out; do
        if [ -z "$prev" ]; then
            xrandr --output "$out" --auto --pos 0x0
        else
            xrandr --output "$out" --auto --right-of "$prev"
        fi
        prev="$out"
    done < <(xrandr --query | awk '/ connected/ {print $1}')
}

main() {
    local cmd="${1:-list}"
    if _is_wayland; then
        case "$cmd" in
            detect|auto)        _hyprland_monitors_conf ;;
            list)               _hyprland_list ;;
            mirror)
                # Hyprland equivalent: mirror through the first output
                echo "Hyprland: hyprctl keyword monitor <out>,preferred,0x0,1,mirror,<primary>"
                echo "(no automatic mirror script — see https://wiki.hypr.land/Configuring/Monitors/)" ;;
            extend)             _hyprland_monitors_conf ;;
            lid-close-external) _hyprland_lid_handler ;;
            *) echo "usage: archnexus-display detect|auto|list|mirror|extend|lid-close-external" ;;
        esac
    else
        case "$cmd" in
            detect)             _x11_detect_or_save ;;
            auto)               _x11_auto ;;
            list)               _x11_list ;;
            mirror)             _x11_mirror ;;
            extend)             _x11_extend ;;
            lid-close-external)
                echo "X11: set HandleLidSwitchExternalPower=ignore in /etc/systemd/logind.conf"
                echo "and use xrandr --output eDP-1 --off when external is connected." ;;
            *) echo "usage: archnexus-display detect|auto|list|mirror|extend|lid-close-external" ;;
        esac
    fi
}

main "$@"
