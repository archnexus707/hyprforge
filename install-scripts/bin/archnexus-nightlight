#!/usr/bin/env bash
# archnexus-nightlight — toggle / set color temperature.
# Wayland: wlsunset.  X11: redshift.
#
# Usage:  archnexus-nightlight toggle      (start/stop the daemon)
#         archnexus-nightlight on
#         archnexus-nightlight off
#         archnexus-nightlight cool        (one-shot 6500K)
#         archnexus-nightlight warm        (one-shot 3500K)
#
# Default schedule (when starting the daemon): dusk-to-dawn approximation
# via lat/lon from ~/.config/archnexus/geo or fall back to 50°N 0°E.

set -uo pipefail

_is_wayland() { [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; }

GEO="${HOME}/.config/archnexus/geo"
lat="50.0"; lon="0.0"
if [ -f "$GEO" ]; then
    # geo file format:  lat=...\nlon=...
    # shellcheck disable=SC1090
    . "$GEO"
fi

if _is_wayland; then
    daemon="wlsunset"
    args=(-l "$lat" -L "$lon" -t 3500 -T 6500)
else
    daemon="redshift"
    args=(-l "${lat}:${lon}" -t 6500:3500)
fi
if ! command -v "$daemon" >/dev/null 2>&1; then
    echo "install $daemon (apt install $daemon)" >&2
    exit 1
fi

case "${1:-toggle}" in
    toggle)
        if pgrep -u "$USER" -x "$daemon" >/dev/null; then
            pkill -u "$USER" -x "$daemon"
            notify-send "Night light" "off" 2>/dev/null || echo off
        else
            setsid -f "$daemon" "${args[@]}" >/dev/null 2>&1
            notify-send "Night light" "on (schedule active)" 2>/dev/null || echo on
        fi ;;
    on)
        pgrep -u "$USER" -x "$daemon" >/dev/null || setsid -f "$daemon" "${args[@]}" >/dev/null 2>&1
        notify-send "Night light" "on" 2>/dev/null || echo on ;;
    off)
        pkill -u "$USER" -x "$daemon"; notify-send "Night light" "off" 2>/dev/null || echo off ;;
    cool)
        pkill -u "$USER" -x "$daemon" 2>/dev/null || true
        if _is_wayland; then wlsunset -T 6501 -t 6500 -l "$lat" -L "$lon" & disown $! 2>/dev/null
        else redshift -O 6500 ; fi
        notify-send "Night light" "cool 6500K" 2>/dev/null || echo cool ;;
    warm)
        pkill -u "$USER" -x "$daemon" 2>/dev/null || true
        if _is_wayland; then wlsunset -T 3501 -t 3500 -l "$lat" -L "$lon" & disown $! 2>/dev/null
        else redshift -O 3500 ; fi
        notify-send "Night light" "warm 3500K" 2>/dev/null || echo warm ;;
esac
