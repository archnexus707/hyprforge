#!/usr/bin/env bash
# archnexus-screenrecord — start/stop a screen recording.
# Wayland: wf-recorder (region via slurp, full-screen otherwise).
# X11:     ffmpeg + x11grab.
#
# Modes:
#   toggle       (default) start a recording if none running, else stop
#   region       wf-recorder/slurp region selection (Wayland), -video_size scaled
#   screen       full screen
#   stop         stop the running session and notify
#   status       print PID + output path if recording, else exit 1
#
# Flags:
#   --audio      include default sink (Wayland) or pulse default (X11)
#
# Output: $XDG_VIDEOS_DIR/Screencasts/screencast-<ts>.mp4
# State: $XDG_RUNTIME_DIR/archnexus-screenrecord.pid + .out
#
# Bind it:
#   Hyprland → SUPER SHIFT, R, exec, archnexus-screenrecord toggle
#   i3       → bindsym $mod+Shift+r exec --no-startup-id archnexus-screenrecord toggle

set -uo pipefail

mode="toggle"
audio=0
for a in "$@"; do
    case "$a" in
        toggle|region|screen|stop|status) mode="$a" ;;
        --audio) audio=1 ;;
        -h|--help)
            grep '^#' "$0" | sed 's/^# \{0,1\}//'
            exit 0 ;;
    esac
done

RUN_DIR="${XDG_RUNTIME_DIR:-/tmp}"
PID_FILE="$RUN_DIR/archnexus-screenrecord.pid"
OUT_FILE="$RUN_DIR/archnexus-screenrecord.out"

_is_wayland() {
    [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]
}

# Env preflight — status/stop work without a graphical session, but the
# start path needs DISPLAY or WAYLAND_DISPLAY.
case "$mode" in
    toggle|region|screen)
        if [ -z "${DISPLAY:-}" ] && ! _is_wayland; then
            msg="archnexus-screenrecord needs a graphical session (DISPLAY or WAYLAND_DISPLAY). Run from Hyprland, i3, or XFCE."
            printf 'archnexus-screenrecord: %s\n' "$msg" >&2
            notify-send "archnexus-screenrecord" "$msg" 2>/dev/null || true
            exit 1
        fi
        ;;
esac

_is_running() {
    [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

_stop() {
    if _is_running; then
        local pid; pid=$(cat "$PID_FILE")
        kill -INT "$pid" 2>/dev/null
        # give the recorder a moment to flush + close the container
        for _ in 1 2 3 4 5; do kill -0 "$pid" 2>/dev/null || break; sleep 0.2; done
        kill -KILL "$pid" 2>/dev/null || true
        local out; out=$(cat "$OUT_FILE" 2>/dev/null || true)
        rm -f "$PID_FILE" "$OUT_FILE"
        notify-send "Screen record" "saved: $out" 2>/dev/null || echo "saved: $out"
    else
        notify-send "Screen record" "no active recording" 2>/dev/null || echo "no active recording" >&2
    fi
}

_status() {
    if _is_running; then
        printf 'recording (pid %s) -> %s\n' "$(cat "$PID_FILE")" "$(cat "$OUT_FILE" 2>/dev/null)"
        exit 0
    fi
    echo "not recording"
    exit 1
}

_start() {
    local out_dir="${XDG_VIDEOS_DIR:-$HOME/Videos}/Screencasts"
    mkdir -p "$out_dir"
    local ts; ts=$(date +%Y-%m-%d_%H-%M-%S)
    local out="$out_dir/screencast-${ts}.mp4"

    if _is_wayland; then
        command -v wf-recorder >/dev/null || { notify-send "archnexus-screenrecord" "install wf-recorder (apt install wf-recorder)"; exit 1; }
        local args=()
        if [ "$1" = "region" ]; then
            command -v slurp >/dev/null || { notify-send "archnexus-screenrecord" "install slurp"; exit 1; }
            local geom; geom=$(slurp) || exit 0
            args+=(-g "$geom")
        fi
        [ "$audio" -eq 1 ] && args+=(--audio)
        setsid -f wf-recorder "${args[@]}" -f "$out" >/dev/null 2>&1 < /dev/null &
        local pid=$!
        # wf-recorder via setsid -f detaches; we need its actual PID
        sleep 0.3
        # locate the most recent wf-recorder of this user
        pid=$(pgrep -u "$USER" -nx wf-recorder 2>/dev/null || echo "$pid")
        echo "$pid" > "$PID_FILE"
        echo "$out" > "$OUT_FILE"
        notify-send "Screen record" "started${1:+ ($1)} → $out" 2>/dev/null || echo "recording → $out"
    else
        command -v ffmpeg >/dev/null || { notify-send "archnexus-screenrecord" "install ffmpeg"; exit 1; }
        # Detect primary display geometry via xrandr.
        local geom
        geom=$(xrandr 2>/dev/null | awk '/ primary / {for(i=1;i<=NF;i++) if($i ~ /[0-9]+x[0-9]+\+[0-9]+\+[0-9]+/){print $i; exit}}')
        local size offset
        size="${geom%%+*}"
        offset="${geom#*+}"; offset="+${offset/+/,}"
        local args=(-f x11grab -framerate 30 -video_size "$size" -i "${DISPLAY}.0${offset}")
        if [ "$audio" -eq 1 ]; then
            args+=(-f pulse -i default -c:a aac)
        fi
        args+=(-c:v libx264 -preset veryfast -pix_fmt yuv420p "$out")
        setsid -f ffmpeg "${args[@]}" >/dev/null 2>&1 < /dev/null &
        local pid=$!
        sleep 0.3
        pid=$(pgrep -u "$USER" -nx ffmpeg 2>/dev/null || echo "$pid")
        echo "$pid" > "$PID_FILE"
        echo "$out" > "$OUT_FILE"
        notify-send "Screen record" "started${1:+ ($1)} → $out" 2>/dev/null || echo "recording → $out"
    fi
}

case "$mode" in
    toggle)
        if _is_running; then _stop; else _start region; fi ;;
    region|screen)
        if _is_running; then
            notify-send "archnexus-screenrecord" "already recording — stop first (archnexus-screenrecord stop)" 2>/dev/null || \
                echo "already recording; stop first" >&2
            exit 1
        fi
        _start "$mode" ;;
    stop)   _stop ;;
    status) _status ;;
esac
