  │ SUPER+B          │ firefox                  │
  ├──────────────────┼──────────────────────────┤
  │ SUPER+Q          │ close window             │
  ├──────────────────┼──────────────────────────┤
  │ SUPER+F          │ fullscreen toggle        │
  ├──────────────────┼──────────────────────────┤
  │ SUPER+Space      │ float toggle             │
  ├──────────────────┼──────────────────────────┤
  │ SUPER+S          │ stacking layout          │
  ├──────────────────┼──────────────────────────┤
  │ SUPER+W          │ tabbed layout            │
  ├──────────────────┼──────────────────────────┤
  │ SUPER+V          │ split vertical           │
