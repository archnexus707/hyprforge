[urgency_low]
    background = "#0a0a0f"
    foreground = "#b8b8c0"
    frame_color = "#2a2a3a"
    timeout    = 5

[urgency_normal]
    background = "#0a0a0f"
    foreground = "#fcee0c"
    frame_color = "#00f0ff"
    timeout    = 8

[urgency_critical]
    background = "#0a0a0f"
    foreground = "#ff2e88"
    frame_color = "#ff2e88"
    timeout    = 0
