[urgency_low]
    background = "#24283b"
    foreground = "#a9b1d6"
    frame_color = "#414868"
    timeout    = 5

[urgency_normal]
    background = "#24283b"
    foreground = "#c0caf5"
    frame_color = "#7aa2f7"
    timeout    = 8

[urgency_critical]
    background = "#24283b"
    foreground = "#f7768e"
    frame_color = "#f7768e"
    timeout    = 0
